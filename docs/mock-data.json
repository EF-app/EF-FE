      },
      "useLetters": {
        "code": "export const useLetters = (params) => useInfiniteQuery({ queryKey: ['letters', params], queryFn: ({ pageParam }) => apiClient.get('/letters', { params: { ...params, cursor: pageParam, limit: 20 } }).then(r => r.data), getNextPageParam: (last) => last.meta.hasMore ? last.meta.nextCursor : undefined, staleTime: 2 * 60 * 1000 })"
      },
      "useVoteBalanceGame": {
        "code": "export const useVoteBalanceGame = () => { const qc = useQueryClient(); return useMutation({ mutationFn: ({ gameId, choice }) => apiClient.post(`/balance-games/${gameId}/vote`, { choice }).then(r => r.data.data), onMutate: async ({ gameId, choice }) => { await qc.cancelQueries({ queryKey: ['balance-games', 'today'] }); const prev = qc.getQueryData(['balance-games', 'today']); qc.setQueryData(['balance-games', 'today'], old => ({ ...old, myVote: choice })); return { prev }; }, onError: (_, __, ctx) => qc.setQueryData(['balance-games', 'today'], ctx.prev), onSuccess: (data) => qc.setQueryData(['balance-games', 'today'], old => ({ ...old, ...data })) }) }"
      },
      "useHiProfiles": {
        "code": "export const useHiProfiles = () => useQuery({ queryKey: ['hi-profiles'], queryFn: () => apiClient.get('/hi/profiles', { params: { limit: 10 } }).then(r => r.data.data), staleTime: 5 * 60 * 1000 })"
      },

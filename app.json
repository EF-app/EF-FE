{
  "expo": {
    "name": "EF",
    "slug": "ef-app",
    "scheme": "ef-app-scheme",
    "version": "1.0.0",
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.nokcha.ef",
      "supportsTablet": true
    },
    "android": {
      "package": "com.nokcha.ef",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "androidNavigationBar": {
        "backgroundColor": "#EDEAE7",
        "barStyle": "dark-content"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "fonts": [
      "./assets/fonts/NanumSquareNeo-aLt.ttf",
      "./assets/fonts/NanumSquareNeo-bRg.ttf",
      "./assets/fonts/NanumSquareNeo-cBd.ttf",
      "./assets/fonts/NanumSquareNeo-dEb.ttf",
      "./assets/fonts/NanumSquareNeo-eHv.ttf"
    ]
  }
}
